# Procura AI — Cloudflare Production Environment Variables
# Set these in Cloudflare Dashboard > Pages > procura-ai > Environment Variables

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx

# API
NEXT_PUBLIC_API_URL=https://procura-api.onrender.com/api/v1

# R2 Public URL (set up bucket first, then fill)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# KV Cache TTL in seconds
KV_CACHE_TTL=60

# Render Internal Token (for server-side calls)
INTERNAL_API_TOKEN=a-random-32-char-token
