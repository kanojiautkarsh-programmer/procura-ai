# Procura AI — Local Development Environment
# Copy to .env and fill in values

# API
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
ADDITIONAL_ORIGINS=https://procura-ai.pages.dev

# Database
DATABASE_URL=postgresql://procura:procura_dev@localhost:5432/procura

# Clerk Auth
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
CLERK_ISSUER=your-clerk-domain.clerk.accounts.dev

# Internal API Token (for service-to-service calls)
INTERNAL_API_TOKEN=change-me-to-a-random-32-char-token

# BYOK Encryption (AES-256-GCM master key — must be 32 bytes hex or strong passphrase)
BYOK_ENCRYPTION_KEY=change-me-to-a-secure-key-32-bytes-hex

# Upstash Redis (free tier — for KV cache)
# Create at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# AI Service
AI_SERVICE_URL=http://localhost:8000
